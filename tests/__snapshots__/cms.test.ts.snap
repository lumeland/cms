      action='/document/Homepage/edit'
      method="post"
      class="form"
      id="form-edit"
      enctype="multipart/form-data"
    >
      <u-fields
        data-fields="{&quot;name&quot;:&quot;root&quot;,&quot;type&quot;:&quot;object&quot;,&quot;tag&quot;:&quot;f-object-root&quot;,&quot;fields&quot;:[{&quot;tag&quot;:&quot;f-text&quot;,&quot;label&quot;:&quot;Please, write a title here&quot;,&quot;name&quot;:&quot;title&quot;,&quot;type&quot;:&quot;text&quot;,&quot;description&quot;:&quot;A catchy title works better. Be creative!!&quot;,&quot;attributes&quot;:{&quot;required&quot;:true,&quot;placeholder&quot;:&quot;Example: \\\\&quot;The best blog in the world\\\\&quot;&quot;}},{&quot;tag&quot;:&quot;f-textarea&quot;,&quot;label&quot;:&quot;description&quot;,&quot;name&quot;:&quot;description&quot;,&quot;type&quot;:&quot;textarea&quot;},{&quot;tag&quot;:&quot;f-markdown&quot;,&quot;label&quot;:&quot;content&quot;,&quot;name&quot;:&quot;content&quot;,&quot;type&quot;:&quot;markdown&quot;,&quot;upload&quot;:&quot;my_uploads&quot;},{&quot;tag&quot;:&quot;f-code&quot;,&quot;label&quot;:&quot;extra&quot;,&quot;name&quot;:&quot;extra&quot;,&quot;type&quot;:&quot;code&quot;,&quot;attributes&quot;:{&quot;data&quot;:{&quot;language&quot;:&quot;CSS&quot;}}}]}"
        data-value="{&quot;root&quot;:{}}"
      ></u-fields>
    </form>
  </u-form>

      </div>
      <footer class="app-footer">
        <p>
          Powered by
