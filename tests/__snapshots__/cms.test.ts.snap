    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>new-post.md - Lume CMS</title>
    <link rel="stylesheet" href='/styles.css'>
    <link rel="icon" href='/favicon.ico' sizes="32x32">
    <link
      rel="apple-touch-icon"
      href='/apple-touch-icon.png'
      sizes="180x180"
    >
    <link
      rel="icon"
      href='/favicon.svg'
      sizes="any"
      type="image/svg+xml"
    >
    <link rel="manifest" href="/manifest.json" crossorigin="use-credentials">
    <script type="importmap">
    {
      "imports": {
        "lume_cms/": "/",
        "dom": "https://cdn.jsdelivr.net/gh/oscarotero/dom@0.2.1/dom.js",
        "cropper": "https://cdn.jsdelivr.net/npm/cropperjs@2.1.0/dist/cropper.esm.js"
      }
    }
    </script>
    <script>
      const darkLightModeStorageKey = "__lume_cms__user_theme";
      const contemporaryTheme = localStorage.getItem(
        darkLightModeStorageKey,
      );
      if (contemporaryTheme) {
        document.documentElement.setAttribute(
          "data-theme",
          contemporaryTheme,
        );
      }
    </script>

    <script type="module">
      import "lume_cms/components/ui.js";
      // deno-fmt-ignore-start
      import "lume_cms/components/f-checkbox.js";
import "lume_cms/components/f-choose-list.js";
import "lume_cms/components/f-choose.js";
import "lume_cms/components/f-code.js";
import "lume_cms/components/f-color.js";
import "lume_cms/components/f-current-datetime.js";
import "lume_cms/components/f-date.js";
import "lume_cms/components/f-datetime.js";
import "lume_cms/components/f-email.js";
import "lume_cms/components/f-file-list.js";
import "lume_cms/components/f-file.js";
import "lume_cms/components/f-hidden.js";
import "lume_cms/components/f-list.js";
import "lume_cms/components/f-map.js";
import "lume_cms/components/f-markdown.js";
import "lume_cms/components/f-number.js";
import "lume_cms/components/f-object-list.js";
import "lume_cms/components/f-object.js";
import "lume_cms/components/f-radio.js";
import "lume_cms/components/f-relation-list.js";
import "lume_cms/components/f-rich-text.js";
import "lume_cms/components/f-relation.js";
import "lume_cms/components/f-select.js";
import "lume_cms/components/f-text.js";
import "lume_cms/components/f-textarea.js";
import "lume_cms/components/f-time.js";
import "lume_cms/components/f-url.js";
      // deno-fmt-ignore-end
    </script>

    
  </head>
  <body>
    <div class="app-container" tabindex="-1">
      <div class="app">
        
  <header class="header">
    <nav class="app-nav" aria-label="You are here:">
  <ul class="breadcrumb">
    

    <li>
      <a href="/"><u-icon name="house-fill"></u-icon> Home</a>
    </li>

    
      
        <li><a href="/collection/posts">My posts</a></li>
      
    
  </ul>

  
  <button
    class="buttonIcon is-secondary"
    type="button"
    command="toggle-popover"
    commandfor="user-menu"
    aria-label="
      
        No authentication
      
    "
  >
    <u-icon name='user-circle'></u-icon>
  </button>

  <div popover="auto" class="menu" id="user-menu">
    <p class="menu-header">
      
      
        No authentication
      
    
    </p>

    
    

    <button
      class="button is-secondary"
      type="button"
      onclick="\$ui.toggleTheme()"
    >
      <u-icon name="circle-half-fill"></u-icon>
      Switch theme
    </button>

    <button
      class="button is-secondary"
      type="button"
      onclick="\$ui.togglePreview()"
    >
      <u-icon name="square-half"></u-icon>
      Toggle preview
    </button>

    
  
  </div>


</nav>

    <h1 class="header-title">
      new-post.md
    </h1>
  </header>

  <nav class="navigation">
    
      <button
        class="button is-primary"
        type="submit"
        form="form-edit"
        tabindex="1"
      >
        <u-icon name="floppy-disk"></u-icon>
        Save changes
      </button>
    

    
  <button
    class="buttonIcon is-secondary"
    type="button"
    command="toggle-popover"
    commandfor="edit-menu"
    aria-label="Edit options"
  >
    <u-icon name='dots-three-vertical'></u-icon>
  </button>

  <div popover="auto" class="menu" id="edit-menu">
    <p class="menu-header">
      Edit options
    </p>

    
      
        <a
          class="button is-secondary"
          href="https://lume.land"
          target="_blank"
        >
          <u-icon name="arrow-square-out"></u-icon>
          Open page
        </a>
      
      
        <a
          class="button is-secondary"
          href='/collection/posts/new-post.md/code'
        >
          <u-icon name="code"></u-icon>
          Edit code
        </a>
      

      
        <button
  command="show-modal"
  commandfor="modal-rename"
  class="button is-secondary"
  type="button"
>
  
            <u-icon name="arrow-square-right"></u-icon>
            Move file
          
</button>

<dialog class="modal is-center" id="modal-rename">
  <button
    type="button"
    class="buttonIcon modal-close"
    command="close"
    commandfor="modal-rename"
  >
    <u-icon name="x"></u-icon>
  </button>

  
          

          <form
            method="post"
            action='/collection/posts/new-post.md/move'
          >
            <div class="field">
              <label for="file-name">New path</label>
              <input
                id="file-name"
                class="input"
                type="text"
                required
                autofocus
                value="new-post.md"
                name="name"
              >
            </div>

            <footer class="field-footer">
              <button class="button is-primary">Move file</button>
            </footer>
          </form>
        
</dialog>

      

      
        <button
  command="show-modal"
  commandfor="modal-duplicate"
  class="button is-secondary"
  type="button"
>
  
            <u-icon name="copy"></u-icon>
            Save as…
          
</button>

<dialog class="modal is-center" id="modal-duplicate">
  <button
    type="button"
    class="buttonIcon modal-close"
    command="close"
    commandfor="modal-duplicate"
  >
    <u-icon name="x"></u-icon>
  </button>

  
          

          <u-form-join data-form="form-edit">
            <form
              method="post"
              action='/collection/posts/new-post.md/duplicate'
            >
              
                <div class="field">
                  <label for="file-name">Document name</label>
                  <input
                    id="file-name"
                    class="input"
                    type="text"
                    required
                    autofocus
                    value="new-post.md"
                    name="name"
                  >
                </div>
              

              <footer class="field-footer">
                <button class="button is-primary">Save copy</button>
              </footer>
            </form>
          </u-form-join>
        
</dialog>

      

      
        <u-confirm data-message="Are you sure?">
          <button
            class="button is-secondary"
            type="submit"
            form="form-edit"
            formAction='/collection/posts/new-post.md/delete'
          >
            <u-icon name="trash"></u-icon>
            Delete
          </button>
        </u-confirm>
      
    
  </div>


  </nav>

  <u-form>
    
      <u-views
        data-target="form-edit"
        data-state="[]"
        data-views="[&quot;title&quot;]"
      >
        <strong class="field-label">View:</strong>
      </u-views>
    

    <form
      action='/collection/posts/new-post.md/edit'
      method="post"
      class="form"
      enctype="multipart/form-data"
      id="form-edit"
    >
      <u-fields
        data-fields="{&quot;name&quot;:&quot;root&quot;,&quot;type&quot;:&quot;object&quot;,&quot;tag&quot;:&quot;f-object-root&quot;,&quot;fields&quot;:[{&quot;tag&quot;:&quot;f-text&quot;,&quot;label&quot;:&quot;Post title&quot;,&quot;name&quot;:&quot;title&quot;,&quot;type&quot;:&quot;text&quot;,&quot;description&quot;:&quot;This title is perfect!&quot;,&quot;view&quot;:&quot;title&quot;,&quot;attributes&quot;:{&quot;required&quot;:true,&quot;placeholder&quot;:&quot;Example: \\\\&quot;How to create a blog with LumeCMS\\\\&quot;&quot;}},{&quot;tag&quot;:&quot;f-list&quot;,&quot;label&quot;:&quot;tags&quot;,&quot;name&quot;:&quot;tags&quot;,&quot;type&quot;:&quot;list&quot;},{&quot;tag&quot;:&quot;f-current-datetime&quot;,&quot;label&quot;:&quot;date&quot;,&quot;name&quot;:&quot;date&quot;,&quot;type&quot;:&quot;current-datetime&quot;},{&quot;tag&quot;:&quot;f-date&quot;,&quot;label&quot;:&quot;so_data&quot;,&quot;name&quot;:&quot;so_data&quot;,&quot;type&quot;:&quot;date&quot;},{&quot;tag&quot;:&quot;f-datetime&quot;,&quot;label&quot;:&quot;so_datatime&quot;,&quot;name&quot;:&quot;so_datatime&quot;,&quot;type&quot;:&quot;datetime&quot;},{&quot;tag&quot;:&quot;f-color&quot;,&quot;label&quot;:&quot;color&quot;,&quot;name&quot;:&quot;color&quot;,&quot;type&quot;:&quot;color&quot;},{&quot;tag&quot;:&quot;f-file&quot;,&quot;label&quot;:&quot;cover&quot;,&quot;name&quot;:&quot;cover&quot;,&quot;type&quot;:&quot;file&quot;,&quot;relativePath&quot;:true,&quot;upload&quot;:&quot;my_uploads:img/covers&quot;,&quot;publicPath&quot;:&quot;/uploads&quot;},{&quot;tag&quot;:&quot;f-object&quot;,&quot;label&quot;:&quot;Image note&quot;,&quot;name&quot;:&quot;image&quot;,&quot;type&quot;:&quot;object&quot;,&quot;fields&quot;:[{&quot;tag&quot;:&quot;f-text&quot;,&quot;label&quot;:&quot;title&quot;,&quot;name&quot;:&quot;title&quot;,&quot;type&quot;:&quot;text&quot;},{&quot;tag&quot;:&quot;f-file&quot;,&quot;label&quot;:&quot;image&quot;,&quot;name&quot;:&quot;image&quot;,&quot;type&quot;:&quot;file&quot;,&quot;upload&quot;:&quot;my_uploads&quot;,&quot;publicPath&quot;:&quot;/uploads&quot;}]},{&quot;tag&quot;:&quot;f-markdown&quot;,&quot;label&quot;:&quot;Post content&quot;,&quot;name&quot;:&quot;content&quot;,&quot;type&quot;:&quot;markdown&quot;,&quot;relativePath&quot;:true,&quot;upload&quot;:&quot;my_uploads&quot;}]}"
        data-value="{&quot;root&quot;:{&quot;title&quot;:&quot;Title modified&quot;,&quot;tags&quot;:[&quot;Tag 1&quot;,&quot;Tag 3&quot;],&quot;so_data&quot;:&quot;2026-06-21T00:00:00.000Z&quot;,&quot;so_datatime&quot;:&quot;2026-06-21T18:00:00.000Z&quot;,&quot;color&quot;:&quot;#332211&quot;,&quot;cover&quot;:&quot;&quot;,&quot;image&quot;:{&quot;title&quot;:&quot;Image title&quot;,&quot;image&quot;:&quot;/uploads/example2.txt&quot;},&quot;content&quot;:&quot;POST CONTENT\\\\n&quot;}}"
      ></u-fields>
    </form>
  </u-form>

      </div>
      <footer class="app-footer">
        <p>
          Powered by
          <a href="https://lume.land/cms/">
            LumeCMS (local)
          </a>
        </p>
      </footer>
    </div>

    <u-pagepreview data-url="https://lume.land"></u-pagepreview>
  </body>
</html>

\`
`;

